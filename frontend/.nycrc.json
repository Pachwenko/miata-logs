{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "include": ["src/**/*.{ts,tsx}"],
  "exclude": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/index.ts",
    "src/main.tsx"
  ],
  "reporter": ["html", "text", "json", "lcov"],
  "report-dir": "coverage",
  "temp-dir": ".nyc_output",
  "lines": 70,
  "functions": 70,
  "branches": 60,
  "statements": 70,
  "check-coverage": false,
  "skip-full": false,
  "per-file": false
}
